{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: update_data",
            "type": "debugpy",
            "request": "launch",
            "purpose": ["debug-in-terminal"],
            "module": "scraper_service.update_data",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "stopOnEntry": true,
            "console": "integratedTerminal",
            "env": {
                "PLAYWRIGHT_USER_DATA_DIR": "/runtime/playwright-user-data",
                "SCRAPER_STORAGE_DIR": "/runtime/storage"
            }
        },
        {
            "name": "Python: archivo activo",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "python": "${command:python.interpreterPath}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: pytest archivo activo",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-s",
                "-vv"
            ],
            "cwd": "${workspaceFolder}",
            "python": "${command:python.interpreterPath}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PLAYWRIGHT_USER_DATA_DIR": "/runtime/playwright-user-data",
                "SCRAPER_STORAGE_DIR": "/runtime/storage"
            }
        },
        {
            "name": "Python: Remote Attach",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/scraper_service",
                    "remoteRoot": "/app/scraper_service"
                }
            ]
        }
    ]
}
